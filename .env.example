# Skabelon for environment-variabler.
# Kopier til .env og udfyld. .env committes IKKE (er i .gitignore).

# Lokal SQLite (default hvis ikke sat):
# DATABASE_URL=sqlite:///./local.db

# Lokal PostgreSQL (hvis du installerer Postgres lokalt):
# DATABASE_URL=postgresql://user:password@localhost:5432/konkurrenttracker

# Railway PostgreSQL (saettes automatisk af Railway naar du tilfoejer Postgres add-on):
# DATABASE_URL=postgresql://user:password@host:port/railway

ENVIRONMENT=development

# Anthropic API (bruges fra Sprint 03)
# ANTHROPIC_API_KEY=sk-ant-...

# Postmark (bruges fra Sprint 05)
# POSTMARK_SERVER_TOKEN=...
