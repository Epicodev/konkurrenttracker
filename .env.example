# Skabelon for environment-variabler.
# Kopier til .env og udfyld. .env committes IKKE (er i .gitignore).

# Database (lokal default = SQLite). Paa Railway saettes automatisk af Postgres add-on.
# DATABASE_URL=sqlite:///./local.db
# DATABASE_URL=postgresql://user:pass@host:port/db

ENVIRONMENT=development

# Anthropic API til Haiku-klassificering + Sonnet-syntese (Sprint 03)
# ANTHROPIC_API_KEY=sk-ant-...

# Postmark til ugentlig PDF-mail (Sprint 05)
# POSTMARK_SERVER_TOKEN=...

# HTTP Basic Auth til /api/* og /admin/* (Sprint 04). Hvis ikke sat, ingen auth (lokal dev).
# BASIC_AUTH_USER=epico
# BASIC_AUTH_PASSWORD=skiftMig

# Slack-webhook til driftsalerts ved scraper-fejl
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
